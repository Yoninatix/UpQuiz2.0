# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=examdb
POSTGRES_USER=examuser
POSTGRES_PASSWORD=exampassword

# ─── HMAC / JWT ───────────────────────────────────────────────────────────────
# Used for HMAC-SHA256 (HS256) JWT signing — generate with: openssl rand -hex 64
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRY_HOURS=24
# Cookie mode: tokens are sent as HTTP-only cookies (no localStorage)
COOKIE_SECURE=false         # set true in production (HTTPS)
COOKIE_SAME_SITE=Lax        # Strict | Lax | None

# ─── Go Backend ───────────────────────────────────────────────────────────────
GO_BACKEND_PORT=8080
GO_ENV=development

# ─── TypeScript AI Service ────────────────────────────────────────────────────
AI_SERVICE_PORT=3001
AI_SERVICE_URL=http://ai-service:3001

# ─── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION=document_chunks

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
# Recommended: gemma3:4b (~2.5 GB RAM). Alternatives: gemma3:1b (lighter), llama3.2:3b, phi3:mini
OLLAMA_MODEL=gemma3:4b

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Relative paths work when nginx reverse proxy is running on port 80
VITE_API_BASE_URL=/api
VITE_AI_SERVICE_URL=/ai
# Use absolute URLs only for local dev without nginx:
# VITE_API_BASE_URL=http://localhost:8080/api
# VITE_AI_SERVICE_URL=http://localhost:3001

# ─── Nginx ────────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
